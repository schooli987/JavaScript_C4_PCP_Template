<head>
  <meta charset="UTF-8" />
  <title>Hero Carousel</title>
  <link rel="stylesheet" href="styles.css" />
</head>

<body>

  <section class="hero-carousel" id="carousel">
    <div class="carousel-track">

      <div class="slide active">
        <img src="https://picsum.photos/id/1018/1600/700" alt="Slide 1">
      </div>

      <div class="slide">
        <img src="https://picsum.photos/id/1015/1600/700" alt="Slide 2">
      </div>

      <div class="slide">
        <img src="https://picsum.photos/id/1019/1600/700" alt="Slide 3">
      </div>

    </div>

    <!-- Navigation Arrows -->
    <button class="nav prev">&#10094;</button>
    <button class="nav next">&#10095;</button>

    <!-- Indicators -->
    <div class="indicators">
      <span class="dot active" data-slide="0"></span>
      <span class="dot" data-slide="1"></span>
      <span class="dot" data-slide="2"></span>
    </div>
  </section>

  <script src="script.js"></script>
</body>
